# Environment Configuration
# Copy this file to .env and fill in your values

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Model Configuration
MODEL_PATH=./best(1).pt
CONFIDENCE_THRESHOLD=0.5
MAX_IMAGE_SIZE=1024

# File Upload Configuration
MAX_FILE_SIZE_MB=50

# Logging
LOG_LEVEL=INFO

# Deployment
ENVIRONMENT=production
